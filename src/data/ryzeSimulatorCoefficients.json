  "formula": {
    "descriptionCn": "瑞天帝无限递归循环的完整数学公式。loopCore使用四路径模型。",
    "loopCore": {
      "descriptionCn": "loopCore = 四条转换路径之和。每条路径代表法力值→最终AP的不同路线。",
      "path1": {
        "nameCn": "法力→AD→AP",
        "formula": "mana_to_ad × ad_mult × ad_to_ap",
        "sources": "mana_to_ad(魔宗0.02), ad_mult(默认1.0), ad_to_ap(物理转魔法1.67)"
      },
      "path2": {
        "nameCn": "法力→AP (直接)",
        "formula": "mana_to_ap",
        "sources": "mana_to_ap(大天使0.02)"
      },
      "path3": {
        "nameCn": "法力→HP→AD→AP",
        "formula": "mana_to_hp × hp_mult × hp_to_ad × lowHpAdMultiplier × ad_mult × ad_to_ap",
        "sources": "mana_to_hp(末日寒冬0.15), hp_mult(全部hp_mult乘区), hp_to_ad(霸王血铠0.025), lowHpAdMultiplier(1.12或1.0), ad_mult(默认1.0), ad_to_ap(1.67)"
      },
      "path4": {
        "nameCn": "法力→HP→AP",
        "formula": "mana_to_hp × hp_mult × hp_to_ap",
        "sources": "mana_to_hp(末日寒冬0.15), hp_mult(全部hp_mult乘区), hp_to_ap(裂隙制造者0.02)"
      },
      "loopCoreFormula": "loopCore = path1 + path2 + path3 + path4"
    },
    "loopFactor": {
      "formula": "loopFactor = flatMana × 0.001 × loopCore × ap_mult",
      "flatMana": "baseMana(1490) + ΣitemFlatMana",
      "ap_mult_definition": "所有ap_mult来源根据multiplicative开关聚合后的总ap倍率",
      "overflowRule": "loopFactor >= 1",
      "overflowCap": 2147483647,
      "overflowCapNote": "32位有符号整数上限 2^31-1 ≈ 21.47亿"
    },
    "multiplierAggregation": {
      "multiplicative": {
        "ap_mult_total": "∏ (1 + ap_mult_i)  for i in active ap_mult sources",
        "hp_mult_total": "∏ (1 + hp_mult_i)  for i in active hp_mult sources",
        "ad_mult_total": "∏ (1 + ad_mult_i)  for i in active ad_mult sources"
      },
      "additive": {
        "ap_mult_total": "1 + Σ ap_mult_i  for i in active ap_mult sources",
        "hp_mult_total": "1 + Σ hp_mult_i  for i in active hp_mult sources",
        "ad_mult_total": "1 + Σ ad_mult_i  for i in active ad_mult sources"
      }
    },
